  <!-- PAGE 6: Rule Catalog Resolution                               -->
  <!-- ============================================================ -->
  <diagram name="06 Rule Catalog Resolution" id="m06">
  <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
  <root>
  <mxCell id="0"/><mxCell id="1" parent="0"/>
  <mxCell id="title" value="Rule Catalog Resolution Pattern â€” How rule_version_id is resolved and pinned at intake" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="1100" height="35" as="geometry"/></mxCell>
  <!-- Components -->
  <mxCell id="a1" value="filing-service&#xa;[VAT-GENERIC]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="80" y="200" width="170" height="80" as="geometry"/></mxCell>
  <mxCell id="a2" value="Rule Catalog mechanism&#xa;[VAT-GENERIC]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="400" y="200" width="190" height="80" as="geometry"/></mxCell>
  <mxCell id="a3" value="Rule Catalog&#xa;[DK VAT data]&#xa;ML Â§Â§ legal references" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="400" y="400" width="190" height="110" as="geometry"/></mxCell>
  <mxCell id="a4" value="rule-engine-service&#xa;[DK VAT]&#xa;Pure evaluation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="700" y="200" width="170" height="80" as="geometry"/></mxCell>
  <mxCell id="a5" value="Filing record&#xa;rule_version_id pinned" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="80" y="420" width="170" height="100" as="geometry"/></mxCell>
  <!-- Steps -->
  <mxCell id="step1" value="Step 1: filing-service receives POST /vat-filings (period_end in payload)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="80" y="80" width="600" height="50" as="geometry"/></mxCell>
  <mxCell id="step2box" value="Step 2: version resolution&#xa;SELECT rule_version WHERE effective_from &lt;= period_end &lt;= effective_to" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="400" y="340" width="300" height="50" as="geometry"/></mxCell>
  <mxCell id="step3box" value="Step 3: rule_version_id pinned to Filing record immediately on intake.&#xa;Rule changes deployed after intake DO NOT affect in-flight filings." style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="80" y="550" width="500" height="60" as="geometry"/></mxCell>
  <mxCell id="step4box" value="Step 4: rule-engine-service loads all rules for the&#xa;pinned rule_version_id from catalog (cached p99 &lt; 100ms).&#xa;Executes 8 DK VAT rule packs in order." style="text;html=1;strokeColor=#d6b656;fillColor=#ffe6cc;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="700" y="350" width="350" height="80" as="geometry"/></mxCell>
  <!-- No-gap constraint -->
  <mxCell id="nogap" value="No-gap constraint:&#xa;Rule history must be contiguous â€” no period gaps allowed.&#xa;Gap = version resolution failure = intake blocked." style="text;html=1;strokeColor=#FF0000;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="700" y="480" width="350" height="80" as="geometry"/></mxCell>
  <!-- Determinism note -->
  <mxCell id="det" value="Determinism guarantee [VAT-GENERIC principle]:&#xa;evaluate(facts, rule_version_id) â†’ outcomes&#xa;Pure function Â· Same input+version = identical output always&#xa;Enables legal replay of any historical filing." style="text;html=1;strokeColor=#d6b656;fillColor=#ffe6cc;align=left;verticalAlign=middle;spacingLeft=8;overflow=hidden;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="700" y="590" width="450" height="90" as="geometry"/></mxCell>
  <!-- Edges -->
  <mxCell id="e1" value="1. POST /vat-filings (period_end)" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="a1" target="a2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  <mxCell id="e2" value="2. resolve rule_version_id" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="a2" target="a3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  <mxCell id="e3" value="3. pin rule_version_id" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="a1" target="a5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  <mxCell id="e4" value="4. evaluate(facts, rule_version_id)" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="a1" target="a4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  <mxCell id="e5" value="5. load rules for version (cached)" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="a4" target="a3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root></mxGraphModel>
  </diagram>

