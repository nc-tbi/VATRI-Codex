{
  "name": "tax-core",
  "version": "1.0.0",
  "private": true,
  "description": "Tax Core Phase 1 — monorepo (domain package + microservices)",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "test": "npm run test -w @tax-core/domain",
    "test:watch": "npm run test:watch -w @tax-core/domain",
    "test:gate-a": "npm run test && npm run typecheck",
    "test:gate-b": "npm run test && npm run typecheck",
    "test:svc-integration": "npm run test -w @tax-core/domain -- src/__tests__/phase1-defect-prevention-004.test.ts src/__tests__/phase1a-service-integration-gate-a-svc.test.ts",
    "test:phase3-integration": "npm run test -w @tax-core/domain -- src/__tests__/phase3-claims-gate-c.test.ts",
    "test:phase3-resilience": "npm run test -w @tax-core/domain -- src/__tests__/phase3-claims-resilience-gate-c.test.ts",
    "test:phase3-observability": "npm run test -w @tax-core/domain -- src/__tests__/phase3-observability-gate-c.test.ts",
    "test:phase3-gate-c": "npm run test:phase3-integration && npm run test:phase3-resilience && npm run test:phase3-observability",
    "ci:guardrails": "node scripts/ci/validate-guardrails.mjs",
    "ci:migration-compat": "node scripts/ci/validate-migration-compat.mjs",
    "ci:phase3": "node scripts/ci/run-phase3-gate.mjs --lane all --guardrails",
    "ci:phase3-cycle": "npm run ci:migration-compat && npm run ci:phase3",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "docker compose -f docker-compose.services.yml up --build",
    "infra:up": "docker compose -f local/docker-compose.local.yml up -d",
    "infra:down": "docker compose -f local/docker-compose.local.yml down"
  },
  "devDependencies": {
    "swagger-ui-dist": "^5.17.14"
  }
}
