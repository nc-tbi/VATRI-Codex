# Auth service base URL (portal auth gateway, port 3009)
PORTAL_API_BASE_URL=http://localhost:3009
PORTAL_BFF_BASE_URL=http://localhost:3009
TRACE_PROPAGATION_ENABLED=true

# Auth-service runtime settings.
NODE_ENV=development
SERVICE_PORT=3000

# Non-production only seeded admin bootstrap contract.
# auth-service will throw a fatal startup error if ADMIN_SEED_ENABLED=true in NODE_ENV=production.
ADMIN_SEED_ENABLED=true
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=adminadmin

# Non-placeholder local/dev secrets for immediate bootstrap.
# Replace and inject from secret manager for shared/dev/test/prod environments.
SESSION_SIGNING_KEY=local-dev-signing-key-20260225-min-32-characters
SESSION_ENCRYPTION_KEY=local-dev-encryption-key-20260225-min-32-characters
