  <!-- DK VAT configs (left column) -->
  <mxCell id="d1" value="DK VAT Filing Schema&#xa;[DK VAT config]&#xa;CVR Â· Rubrik A/B/C&#xa;salgsmoms / kÃ¸bsmoms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="200" height="90" as="geometry"/></mxCell>
